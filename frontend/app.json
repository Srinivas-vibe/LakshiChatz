{
  "expo": {
    "name": "LakshiChatz",
    "slug": "lakshichatz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "backgroundColor": "#0A051D",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lakshichatz.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#6C63FF"
      },
      "package": "com.lakshichatz.app"
    },
    "plugins": [
      "expo-asset",
      "expo-sqlite",
      "expo-secure-store"
    ]
  }
}
